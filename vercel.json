{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/student/:handle", "destination": "/api/student-page?handle=:handle" }
  ],
  "crons": [
    {
      "path": "/api/cron-daily",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron-weekly",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron-weekly",
      "schedule": "0 14 * * 5"
    }
  ]
}
